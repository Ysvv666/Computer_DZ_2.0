<?xml version="1.0" ?>
<launch>

    <node name="map_server" pkg="map_server" type="map_server" args="/home/duzhong/dzacs/src/resource/maps/map0416.yaml" output="screen"/> 
   
    <node name="lidar_loc" pkg="lidar_process" type="lidar_loc" output="screen">
       
        <param name="base_frame" value="base_link" />
        <param name="odom_frame" value="odom" />
        <param name="laser_frame" value="laser" />
        <param name="laser_topic" value="scan" />
    </node>
    
    <node name="lidar_filter_node" pkg="lidar_process" type="lidar_filter_node" output="screen">
    </node>
</launch>
